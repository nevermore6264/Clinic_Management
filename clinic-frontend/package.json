{
  "name": "clinic-frontend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "clean": "node -e \"const fs=require('fs');const rm=p=>{try{fs.rmSync(p,{recursive:true,force:true});console.log('Removed',p)}catch(e){if(e.code!=='ENOENT')throw e}};rm('.next');rm('node_modules/.cache');\"",
    "dev": "next dev -p 4009",
    "dev:clean": "npm run clean && npm run dev",
    "build": "next build",
    "start": "next start -p 4009",
    "lint": "next lint"
  },
  "dependencies": {
    "@stomp/stompjs": "^7.0.0",
    "bootstrap": "^5.3.3",
    "bootstrap-icons": "^1.13.1",
    "dompurify": "^3.4.2",
    "next": "14.2.5",
    "quill": "^2.0.3",
    "react": "^18.3.1",
    "react-bootstrap": "^2.10.2",
    "react-dom": "^18.3.1",
    "react-qr-code": "^2.0.21",
    "react-quill": "^2.0.0",
    "sockjs-client": "^1.6.1"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "typescript": "^5"
  }
}
