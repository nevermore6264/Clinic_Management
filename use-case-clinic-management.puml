@startuml
' --- Sơ đồ USE CASE CHI TIẾT (UC1–UC34) — màu theo nhóm, bố cục thoáng ---
' Bản tổng quan (ít dây): use-case-clinic-management-tong-quan.puml

skinparam handwritten false
skinparam shadowing false
skinparam backgroundColor #FAFAFA
skinparam defaultFontSize 10
skinparam defaultFontName "Arial"
' polyline: dây gọn hơn ortho trên một số bản render
skinparam linetype polyline
skinparam nodesep 42
skinparam ranksep 38
skinparam Padding 10
skinparam wrapWidth 200
scale max 2600 width

title **Sơ đồ Use Case (chi tiết — UC1–UC34)**\n<size:10>Website đặt lịch & vận hành phòng khám — Medlatec</size>

left to right direction

skinparam usecase {
  FontSize 9
  RoundCorner 8
}
skinparam actor {
  BackgroundColor #FFF8E1
  BorderColor #F57C00
  FontColor #333333
  FontStyle bold
}
skinparam arrow {
  Color #37474F
  Thickness 1
}
skinparam stereotype {
  FontColor #546E7A
  FontSize 8
}
' Khung hệ thống — không dùng #...;line:... trên dòng rectangle (một số bản PlantUML báo lỗi cú pháp)
skinparam rectangle {
  BackgroundColor #FFFFFF
  BorderColor #1565C0
  BorderThickness 2
  FontColor #1565C0
  FontStyle bold
}

actor "Bệnh nhân" as Patient
actor "Lễ tân" as Reception
actor "Bác sĩ" as Doctor
actor "Thu ngân" as Cashier
actor "Quản trị viên" as Admin

rectangle "**Hệ thống Website**\n**đặt lịch & vận hành phòng khám**" as System {

  package "Xác thực & tài khoản" as P1 #E3F2FD {
    usecase "Đăng nhập\n(JWT)" as UC1
    usecase "Đổi mật khẩu" as UC2
    usecase "Tạo tài khoản\n& phân quyền" as UC3
    usecase "Đăng ký tài khoản\n(bệnh nhân)" as UC34
  }

  package "Hồ sơ bệnh nhân" as P2 #E8F5E9 {
    usecase "Tạo hồ sơ\nbệnh nhân" as UC4
    usecase "Cập nhật hồ sơ\nbệnh nhân" as UC5
    usecase "Ẩn / vô hiệu\nhồ sơ bệnh nhân" as UC6
    usecase "Tìm kiếm\nbệnh nhân" as UC7
    usecase "Xem lịch sử\nkhám bệnh" as UC8
  }

  package "Lịch khám & lịch bác sĩ" as P3 #FFF3E0 {
    usecase "Xem danh sách\nbác sĩ & lịch" as UC9
    usecase "Đặt lịch khám" as UC10
    usecase "Kiểm tra\ntrùng lịch" as UC11
    usecase "Hủy / đổi\nlịch khám" as UC26
    usecase "Xem lịch hẹn\ncủa tôi" as UC28
    usecase "Tiếp nhận bệnh nhân\n(check-in)" as UC27
    usecase "Xem hàng chờ\nlượt khám" as UC33
    usecase "Cập nhật\nlịch khám" as UC12
    usecase "Thiết lập ca\nlàm việc bác sĩ" as UC13
    usecase "Cập nhật trạng thái\nlượt khám" as UC14
    usecase "Ghi nhận kết quả khám\n(chẩn đoán / đơn)" as UC15
  }

  package "Dịch vụ & giá" as P4 #F3E5F5 {
    usecase "Xem danh sách\ndịch vụ & giá" as UC30
    usecase "Cập nhật danh mục\ndịch vụ & đơn giá" as UC16
  }

  package "Hóa đơn & thanh toán" as P5 #E0F7FA {
    usecase "Tạo hóa đơn\n& dòng dịch vụ" as UC17
    usecase "Ghi nhận\nthanh toán" as UC18
    usecase "Ghi nhận\nthanh toán online" as UC19
    usecase "Xem hóa đơn &\nlịch sử thanh toán" as UC29
    usecase "In / xuất hóa đơn\n(PDF)" as UC31
    usecase "Đối soát thanh toán\nonline" as UC32
  }

  package "Nhắc lịch & báo cáo" as P6 #FBE9E7 {
    usecase "Nhắc lịch khám\n(tự động)" as UC20
    usecase "Báo cáo\ndoanh thu" as UC21
    usecase "Xuất file Excel\ndoanh thu" as UC22
  }

  package "Hỗ trợ vận hành" as P7 #ECEFF1 {
    usecase "Chat nội bộ\n(WebSocket)" as UC23
    usecase "Xem lịch sử\nchat" as UC24
  }

  package "Tổng quan" as P8 #E8EAF6 {
    usecase "Xem dashboard\n(thống kê)" as UC25
  }
}

